{
  "name": "slate",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.14.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite",
    "build": "tsc --noEmit && electron-vite build",
    "engine:package": "uv run --project engine --group dev python engine/package_sidecar.py",
    "preview": "electron-vite preview",
    "dist": "pnpm build && pnpm engine:package && electron-builder",
    "dist:mac": "pnpm build && pnpm engine:package && electron-builder --mac",
    "dist:win": "pnpm build && pnpm engine:package && electron-builder --win",
    "dist:linux": "pnpm build && pnpm engine:package && electron-builder --linux",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/merriweather": "^5.2.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.131.35",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-bold": "^3.20.4",
    "@tiptap/extension-hard-break": "^3.20.4",
    "@tiptap/extension-history": "^3.20.4",
    "@tiptap/extension-italic": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-text": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compromise": "^14.15.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "diff": "^8.0.3",
    "embla-carousel-react": "^8.6.0",
    "fountain-js": "^1.2.4",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^6.1.200",
    "pdfmake": "^0.3.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "syllable": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.19.15",
    "@types/pdfmake": "^0.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
